# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── TRAEFIK ──────────────────────────────────────────────────────────────────
# Generate with: htpasswd -nb your_username your_password
# Example output: admin:$apr1$xyz...
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$CHANGE_ME

# ─── POSTGRES ─────────────────────────────────────────────────────────────────
POSTGRES_USER=dawei
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=dawei_db

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── GITHUB ───────────────────────────────────────────────────────────────────
# Your GitHub username (used for ghcr.io image paths)
GITHUB_REPOSITORY_OWNER=dawei7
